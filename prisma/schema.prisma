datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CLIENT
  PROFESSIONAL
}

enum AccountStatus {
  PENDING
  EMAIL_VERIFIED
  ACTIVE
  REJECTED
  SUSPENDED
}

enum TurnoState {
  DISPONIBLE
  RESERVADO
  CANCELADO
  COMPLETADO
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  hashedPassword String
  name           String
  role           Role           @default(CLIENT)
  status         AccountStatus  @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  // Relaciones
  turnosReservados Turno[]      @relation("ClienteTurnos")
  turnosCreados    Turno[]      @relation("AdminTurnos")
  
  // FASE 2
  subscriptions    Subscription[]
  dinamometrias    Dinamometria[] @relation("ClienteDinamo")

  @@index([email])
  @@index([status])
}

model Professional {
  id           String   @id @default(uuid())
  name         String
  specialty    String
  email        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  serviceId    String
  service      Service  @relation(fields: [serviceId], references: [id])
  turnos       Turno[]

  @@index([active])
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float    // Precio personalizable
  duration    Int      // Duración en minutos
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  professionals Professional[]
  turnos       Turno[]

  @@index([active])
}

model Turno {
  id             String       @id @default(uuid())
  fechaInicio    DateTime
  duracion       Int          // Heredado del servicio al reservar/crear
  estado         TurnoState   @default(DISPONIBLE)
  notas          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relación con Servicio
  serviceId      String
  service        Service      @relation(fields: [serviceId], references: [id])

  // Relación con Profesional
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])

  // Relación con Cliente (quien reserva)
  clientId       String?
  client         User?        @relation("ClienteTurnos", fields: [clientId], references: [id])

  // Suscripción que financió esta reserva (para reintegro de crédito al cancelar)
  subscriptionId String?

  // Relación con Administrador (quien crea)
  createdById    String
  createdBy      User         @relation("AdminTurnos", fields: [createdById], references: [id])

  // Control de concurrencia optimista
  version        Int          @default(0)

  @@index([fechaInicio])
  @@index([clientId])
  @@index([estado])
  @@index([professionalId])
  @@index([serviceId])
}

// FASE 2: Planes y Suscripciones (Esqueleto)
model Plan {
  id            String         @id @default(uuid())
  nombre        String
  descripcion   String
  price         Float          @default(0) // precio en pesos
  interval      String         @default("month") // month, year
  features      String[]
  limiteTurnos  Int            @default(1)
  activo        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  
  subscriptions Subscription[]
}

model Subscription {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  planId         String
  plan           Plan      @relation(fields: [planId], references: [id])
  estado         String    // ACTIVE, CANCELLED, PAST_DUE
  turnosRestantes Int      @default(0)
  fechaInicio    DateTime  @default(now())
  fechaFin       DateTime?
  paymentGateway String    @default("MERCADOPAGO")
  gatewaySubId   String?

  @@index([userId])
}

model Dinamometria {
  id              String    @id @default(uuid())
  fecha           DateTime  @default(now())
  notas           String?

  // Paciente
  clientId        String
  client          User      @relation("ClienteDinamo", fields: [clientId], references: [id])

  // Datos corporales
  peso            Float?    // kg
  altura          Float?    // m

  // Cuádriceps (N)
  cuadDer         Float?
  cuadIzq         Float?

  // Isquiotibiales (N)
  isquioDer       Float?
  isquioIzq       Float?

  // Abductores (N)
  abdDer          Float?
  abdIzq          Float?

  // Adductores (N)
  addDer          Float?
  addIzq          Float?

  // Eversores de tobillo (N)
  eversorDer      Float?
  eversorIzq      Float?

  // ROM Cadera flexión (cm)
  romCaderaDer    Float?
  romCaderaIzq    Float?

  // ROM Tobillo (cm)
  romTobilloDer   Float?
  romTobilloIzq   Float?

  // Velocidad squat 40kg (m/s)
  velocidadSquat  Float?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([clientId])
  @@index([fecha])
}
