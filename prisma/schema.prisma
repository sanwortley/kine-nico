datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CLIENT
  PROFESSIONAL
}

enum AccountStatus {
  PENDING
  EMAIL_VERIFIED
  ACTIVE
  REJECTED
  SUSPENDED
}

enum TurnoState {
  DISPONIBLE
  RESERVADO
  CANCELADO
  COMPLETADO
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  hashedPassword String
  name           String
  role           Role           @default(CLIENT)
  status         AccountStatus  @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  // Relaciones
  turnosReservados Turno[]      @relation("ClienteTurnos")
  turnosCreados    Turno[]      @relation("AdminTurnos")
  
  // FASE 2
  subscriptions    Subscription[]
  dinamometrias    Dinamometria[] @relation("ClienteDinamo")
  fichas           FichaEvaluacion[] @relation("ClienteFicha")
  programas        Programa[]    @relation("ClientePrograma")
  planilla         PlanillaAtleta? @relation("ClientePlanilla")
  planesArchivo    PlanArchivo[] @relation("ClientePlanArchivo")

  @@index([email])
  @@index([status])
}

model Professional {
  id           String   @id @default(uuid())
  name         String
  specialty    String
  email        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  serviceId    String
  service      Service  @relation(fields: [serviceId], references: [id])
  turnos       Turno[]

  @@index([active])
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float    // Precio personalizable
  duration    Int      // Duración en minutos
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  professionals Professional[]
  turnos       Turno[]

  @@index([active])
}

model Turno {
  id             String       @id @default(uuid())
  fechaInicio    DateTime
  duracion       Int          // Heredado del servicio al reservar/crear
  estado         TurnoState   @default(DISPONIBLE)
  notas          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relación con Servicio
  serviceId      String
  service        Service      @relation(fields: [serviceId], references: [id])

  // Relación con Profesional
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])

  // Relación con Cliente (quien reserva)
  clientId       String?
  client         User?        @relation("ClienteTurnos", fields: [clientId], references: [id])

  // Suscripción que financió esta reserva (para reintegro de crédito al cancelar)
  subscriptionId String?

  // Relación con Administrador (quien crea)
  createdById    String
  createdBy      User         @relation("AdminTurnos", fields: [createdById], references: [id])

  // Control de concurrencia optimista
  version        Int          @default(0)

  @@index([fechaInicio])
  @@index([clientId])
  @@index([estado])
  @@index([professionalId])
  @@index([serviceId])
}

// FASE 2: Planes y Suscripciones (Esqueleto)
model Plan {
  id            String         @id @default(uuid())
  nombre        String
  descripcion   String
  price         Float          @default(0) // precio en pesos
  interval      String         @default("month") // month, year
  features      String[]
  limiteTurnos  Int            @default(1)
  activo        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  
  subscriptions Subscription[]
}

model Subscription {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  planId         String
  plan           Plan      @relation(fields: [planId], references: [id])
  estado         String    // ACTIVE, CANCELLED, PAST_DUE
  turnosRestantes Int      @default(0)
  fechaInicio    DateTime  @default(now())
  fechaFin       DateTime?
  paymentGateway String    @default("MERCADOPAGO")
  gatewaySubId   String?

  @@index([userId])
}

model PlanArchivo {
  id        String   @id @default(uuid())
  clientId  String
  client    User     @relation("ClientePlanArchivo", fields: [clientId], references: [id], onDelete: Cascade)
  nombre    String
  tipo      String   @default("application/pdf")
  tamano    Int      // bytes
  contenido String   @db.Text // base64

  createdAt DateTime @default(now())

  @@index([clientId])
}

model FichaEvaluacion {
  id          String   @id @default(uuid())
  fecha       DateTime @default(now())
  clientId    String
  client      User     @relation("ClienteFicha", fields: [clientId], references: [id])

  // Datos básicos (guardados individualmente para poder filtrar/resumir)
  peso        Float?
  altura      Float?   // en cm
  sexo        String?
  grasaEst    Float?
  deporte     String?
  catPeso     String?

  // Bloques complejos en JSON
  historia         Json?  // {anosEntrenando, lesionesPasadas, lesionesActivas, limitaciones, medicacion, cirugias, deportePrevio, frecuencia, ultimaCompetencia, objetivo}
  romTests         Json?  // Array de {prueba, der, izq, total, obs}
  fuerzaTests      Json?  // Array de {ejercicio, peso, reps}
  capacidadTests   Json?  // {cmj, sj, sprint30, plancha, vo2max, km1, abalakov, dj30, rsiMod, saltoHoriz, cmjUni, djUni, multisaltos, singleHop, tripleHop, crossHop, sideHop, timedHop}
  dinamoExt        Json?  // Dinamometría extendida: más músculos que el módulo básico

  // Observaciones
  fortalezas        String?
  debilidades       String?
  prioridades       String?
  restricciones     String?
  objetivos12sem    String?
  fechaReevaluacion DateTime?
  notas             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([fecha])
}

model Ejercicio {
  id          String   @id @default(uuid())
  nombre      String
  patron      String
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([activo])
  @@index([patron])
  programaEjercicios ProgramaEjercicio[]
}

model PlanillaAtleta {
  id               String   @id @default(uuid())
  clientId         String   @unique
  client           User     @relation("ClientePlanilla", fields: [clientId], references: [id], onDelete: Cascade)

  // Datos personales
  fechaNacimiento  String?
  pesoCorporal     Float?
  largoTibia       Float?
  lugarResidencia  String?
  diferenciaHoraria String?
  telefono         String?

  // Lesión & evolución
  fechaCxLesion    String?
  evolucionMeses   Int?
  fechaInicioRh    String?
  evolucionRhRf    String?
  lesionesCx       String?
  fechasLesiones   String?
  antecedentes     String?
  comportDolor     String?
  estudiosComp     String?
  trabajoProfesion String?

  // Objetivos
  motivoConsulta   String?
  expectativas     String?
  objCorto         String?
  objMediano       String?
  objLargo         String?

  // Experiencia deportiva
  tiempoEntrenando  String?
  vecesXSemana      String?
  tipoEntrenamiento String?
  lesionesPrevias   String?

  // Disponibilidad semanal (JSON: { lun: { actividad, intensidad, obs }, ... })
  disponibilidad   Json?

  // Materiales / lugar
  dondeEntrenar    String?
  elementosDisp    String?
  tiempoDisponible String?

  // Observaciones generales
  observaciones    String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Programa {
  id        String      @id @default(uuid())
  clientId  String
  client    User        @relation("ClientePrograma", fields: [clientId], references: [id], onDelete: Cascade)
  nombre    String      @default("Programa")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  dias      ProgramaDia[]

  @@index([clientId])
}

model ProgramaDia {
  id         String              @id @default(uuid())
  programaId String
  programa   Programa            @relation(fields: [programaId], references: [id], onDelete: Cascade)
  semana     Int
  dia        Int
  ejercicios ProgramaEjercicio[]

  @@unique([programaId, semana, dia])
  @@index([programaId])
}

model ProgramaEjercicio {
  id          String        @id @default(uuid())
  diaId       String
  diaPrograma ProgramaDia   @relation(fields: [diaId], references: [id], onDelete: Cascade)
  ejercicioId String
  ejercicio   Ejercicio     @relation(fields: [ejercicioId], references: [id])
  orden       Int
  categoria   String?
  rir         String?
  descanso    String?
  tempo       String?
  microPausa  String?
  rounds      String?
  timeCap     String?
  series      ProgramaSerie[]

  @@index([diaId])
}

model ProgramaSerie {
  id                  String            @id @default(uuid())
  programaEjercicioId String
  ejercicioPrograma   ProgramaEjercicio @relation(fields: [programaEjercicioId], references: [id], onDelete: Cascade)
  numero              Int
  reps                Int?
  pctRM               Float?
  kg                  Float?

  @@index([programaEjercicioId])
}

model Dinamometria {
  id              String    @id @default(uuid())
  fecha           DateTime  @default(now())
  notas           String?

  // Paciente
  clientId        String
  client          User      @relation("ClienteDinamo", fields: [clientId], references: [id])

  // Datos corporales
  peso            Float?    // kg
  altura          Float?    // m

  // Cuádriceps (N)
  cuadDer         Float?
  cuadIzq         Float?

  // Isquiotibiales (N)
  isquioDer       Float?
  isquioIzq       Float?

  // Abductores (N)
  abdDer          Float?
  abdIzq          Float?

  // Adductores (N)
  addDer          Float?
  addIzq          Float?

  // Eversores de tobillo (N)
  eversorDer      Float?
  eversorIzq      Float?

  // ROM Cadera flexión (cm)
  romCaderaDer    Float?
  romCaderaIzq    Float?

  // ROM Tobillo (cm)
  romTobilloDer   Float?
  romTobilloIzq   Float?

  // Velocidad squat 40kg (m/s)
  velocidadSquat  Float?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([clientId])
  @@index([fecha])
}
